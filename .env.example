# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=algo_trader
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis (Celery broker) ──────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Mirage API ─────────────────────────────────────────────────────────────────
# TODO: Replace with your actual Mirage Trading API credentials
MIRAGE_BASE_URL=https://api.miragetrading.in/v1
MIRAGE_API_KEY=your-api-key
MIRAGE_API_SECRET=your-api-secret

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Trading ───────────────────────────────────────────────────────────────────
PAPER_TRADING=True
PHASE=1
MAX_DAILY_LOSS_INR=500
MAX_OPEN_POSITIONS=3
MAX_PER_STRATEGY=1
RISK_PER_TRADE_PCT=0.01
MINIMUM_CASH_BUFFER=10000
