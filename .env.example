# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_NAME=algo_trader
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis (Celery broker) ──────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Kotak Neo API v2 ───────────────────────────────────────────────────────────
# Get these from https://developer.kotaksecurities.com/
KOTAK_CONSUMER_KEY=your-consumer-key
KOTAK_NEO_FIN_KEY=your-neo-fin-key
# Run 'python manage.py kotak_login' each morning to refresh this token
KOTAK_ACCESS_TOKEN=
KOTAK_MOBILE=your-registered-mobile-with-country-code  # e.g. +919999999999
KOTAK_UCC=your-unique-client-code                      # e.g. AB123
KOTAK_MPIN=your-6-digit-mpin

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Trading ───────────────────────────────────────────────────────────────────
PAPER_TRADING=True   # True = Yahoo Finance data + paper orders (no broker account needed)
PHASE=1
MAX_DAILY_LOSS_INR=500
MAX_OPEN_POSITIONS=3
MAX_PER_STRATEGY=1
RISK_PER_TRADE_PCT=0.01
MINIMUM_CASH_BUFFER=10000
